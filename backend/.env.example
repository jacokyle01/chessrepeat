# MongoDB connection string. Defaults to mongodb://localhost:27017 if unset.
MONGO_URI=mongodb://localhost:27017

# MongoDB database name. Defaults to "chessrepeat" if unset.
MONGO_DB=chessrepeat

# Google OAuth client ID — used as the audience when verifying ID tokens
# at /login. Required; the server returns 401 on every login if missing.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
