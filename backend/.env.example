# Address the HTTP server binds to. Defaults to ":8080" if unset.
LISTEN_ADDR=:8080

# Comma-separated whitelist of origins permitted by CORS and the
# WebSocket upgrade. Echoed back as Access-Control-Allow-Origin only on
# exact match; everything else is rejected. Include scheme + host + port.
# Defaults to "http://localhost:5173" if unset.
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB connection string. Defaults to mongodb://localhost:27017 if unset.
MONGO_URI=mongodb://localhost:27017

# MongoDB database name. Defaults to "chessrepeat" if unset.
MONGO_DB=chessrepeat

# Google OAuth client ID — used as the audience when verifying ID tokens
# at /login. Required; the server fails to start without it.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
