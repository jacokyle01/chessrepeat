# Backend HTTP base URL. The WebSocket URL is derived from this by
# swapping the http(s) scheme for ws(s).
VITE_API_URL=http://localhost:8080

# Google OAuth client ID — must match the backend's GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: Lichess personal access token used for opening-explorer
# / API calls from the frontend. Leave blank for unauthenticated use.
VITE_LICHESS_TOKEN=
