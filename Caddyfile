# The frontend is served by Cloudflare Pages from a separate hostname
# (e.g. chessrepeat.com). This Caddy config only fronts the API.
#
# Caddy auto-provisions a Let's Encrypt cert for the API hostname on
# first boot. Make sure the A record points to the VPS before the
# stack comes up the first time, otherwise ACME will fail and Caddy
# will keep retrying.
#
# Replace api.example.com with your real API hostname.

api.chessrepeat.com {
    reverse_proxy backend:8080
    encode zstd gzip

    # WebSocket upgrade is handled transparently by reverse_proxy in
    # Caddy 2 — no extra block needed.
}
