# Copy this to `.env` on the VPS (in the same directory as
# docker-compose.yml). Never commit the real .env. Restrict its
# permissions: `chmod 600 .env`.

# GitHub user/org that owns the GHCR images (used to build the
# ghcr.io/<owner>/chessrepeat-{backend,frontend} pull paths).
GH_OWNER=jacokyle01

# Pin to a specific git SHA for prod, or leave as `latest` to follow
# main. Each successful workflow run pushes both `:latest` and `:<sha>`.
IMAGE_TAG=latest

# Postgres credentials. The DB is reachable only on the docker
# network, so password strength is "moderately important", not
# "internet-facing".
POSTGRES_USER=chessrepeat
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=chessrepeat

# Backend runtime config.
GOOGLE_CLIENT_ID=
ALLOWED_ORIGINS=https://example.com
