# Caddy auto-provisions Let's Encrypt certs for both hostnames on
# first boot. Make sure both A records point to the VPS before the
# stack comes up the first time, otherwise ACME will fail and
# Caddy will keep retrying.
#
# Replace example.com with your real domain.

example.com {
    reverse_proxy frontend:80
    encode zstd gzip
}

api.example.com {
    reverse_proxy backend:8080
    encode zstd gzip

    # WebSocket upgrade is handled transparently by reverse_proxy in
    # Caddy 2 — no extra block needed.
}
